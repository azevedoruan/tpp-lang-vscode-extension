{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "tpp lang",
	"patterns": [
		{
			"include": "#keywords"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#entities"
		},
		{
			"include": "#comments"
		},
		{
			"include": "#constants"
		}
	],
	"repository": {
		"keywords": {
			"patterns": [
				{
					"name": "keyword.control.tpp",
					"match": "\\b(se|então|senão|fim|repita|até|retorna)\\b"
				}
			]
		},
		"strings": {
			"name": "string.quoted.double.tpp",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"name": "constant.character.escape.tpp",
					"match": "\\\\."
				}
			]
		},
		"entities": {
			"patterns": [
				{
					"include": "#type"
				},
				{
					"include": "#function"
				}
			],
			"repository": {
				"type": {
					"name": "entity.name.type",
					"match": "\\b(inteiro|flutuante)\\b"
				},
				"function": {
					"name": "entity.name.function",
					"match": "\\w+\\s*\\("
				}
			}
		},
		"comments": {
			"name": "comment.block",
			"begin": "\\{",
			"end": "\\}",
			"patterns": [
				{
					"name": "constant.character.escape.tpp",
					"match": "\\\\."
				}
			]
		},
		"constants": {
			"patterns": [
				{
					"name": "constant.numeric",
					"match": "\\d"
				}
			]
		}
	},
	"scopeName": "source.tpp"
}